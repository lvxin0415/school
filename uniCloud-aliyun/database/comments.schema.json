{
  "bsonType": "object",
  "required": ["post_id", "user_id", "content"],
  "permission": {
    "read": true,
    "create": "auth.uid != null",
    "update": "doc.user_id == auth.uid || 'admin' in auth.role",
    "delete": "'admin' in auth.role"
  },
  "properties": {
    "_id": { "description": "评论ID" },
    "post_id": { "bsonType": "string", "title": "帖子ID", "foreignKey": "posts._id" },
    "user_id": { "bsonType": "string", "title": "评论用户ID", "foreignKey": "uni-id-users._id" },
    "content": { "bsonType": "string", "title": "评论内容", "maxLength": 200 },
    "anonymous_name": { "bsonType": "string", "title": "匿名昵称" },
    "avatar_color": { "bsonType": "string", "title": "匿名头像色" },
    "created_at": { "bsonType": "timestamp", "title": "创建时间" }
  }
}
