{
  "bsonType": "object",
  "required": ["title"],
  "permission": {
    "read": true,
    "create": "'admin' in auth.role",
    "update": "'admin' in auth.role",
    "delete": "'admin' in auth.role"
  },
  "properties": {
    "_id": { "description": "活动ID" },
    "title": { "bsonType": "string", "title": "活动标题", "maxLength": 50 },
    "content": { "bsonType": "string", "title": "活动内容" },
    "cover_url": { "bsonType": "string", "title": "封面图" },
    "location": { "bsonType": "string", "title": "地点" },
    "start_time": { "bsonType": "string", "title": "开始时间" },
    "end_time": { "bsonType": "string", "title": "结束时间" },
    "is_top": { "bsonType": "bool", "title": "是否置顶", "defaultValue": false },
    "is_banner": { "bsonType": "bool", "title": "是否展示在Banner", "defaultValue": false },
    "status": { "bsonType": "string", "title": "状态", "defaultValue": "active" },
    "created_at": { "bsonType": "timestamp", "title": "创建时间" }
  }
}
