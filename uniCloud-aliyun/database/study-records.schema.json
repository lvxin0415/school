{
  "bsonType": "object",
  "required": ["user_id", "duration_min"],
  "permission": {
    "read": "doc.user_id == auth.uid || 'admin' in auth.role",
    "create": "auth.uid != null",
    "update": false,
    "delete": "'admin' in auth.role"
  },
  "properties": {
    "_id": { "description": "记录ID" },
    "user_id": { "bsonType": "string", "title": "用户ID", "foreignKey": "uni-id-users._id" },
    "duration_min": { "bsonType": "int", "title": "学习时长(分钟)" },
    "subject": { "bsonType": "string", "title": "科目" },
    "note": { "bsonType": "string", "title": "打卡感言", "maxLength": 100 },
    "date": { "bsonType": "string", "title": "日期 YYYY-MM-DD" },
    "time_str": { "bsonType": "string", "title": "时间字符串" },
    "created_at": { "bsonType": "timestamp", "title": "创建时间" }
  }
}
